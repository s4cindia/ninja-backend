# Server Configuration
NODE_ENV=development
PORT=3002

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ninja

# JWT Configuration
JWT_SECRET=your-jwt-secret-here-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-here-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration
REDIS_URL=redis://localhost:6379
# Or use individual settings:
# REDIS_HOST=localhost
# REDIS_PORT=6379

# File Upload Configuration
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=104857600

# EPUB Storage - REQUIRED for production (must be persistent volume)
# Default: /tmp/epub-storage (WARNING: files lost on restart)
EPUB_STORAGE_PATH=/data/epub-storage

# EPUBCheck Configuration (requires Java)
EPUBCHECK_PATH=/home/runner/workspace/lib/epubcheck/epubcheck-5.1.0/epubcheck.jar

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Keys (when needed)
# GEMINI_API_KEY=your-gemini-api-key

# Email Notifications (Batch Completion)
# EMAIL_PROVIDER: 'smtp' for local + staging (Gmail), 'ses' for production (AWS SES)
EMAIL_PROVIDER=smtp

# Gmail SMTP — used for local and staging
# 1. Enable 2FA on your Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=noreply@ninja-platform.com

# App URL — used in email links (set to your Replit/staging URL)
APP_URL=https://your-app.replit.dev

# AWS SES — production only (EMAIL_PROVIDER=ses)
# Uses ECS task role credentials — no key/secret needed in ECS
SES_REGION=us-east-1

# ML Zone Detection — Docling sidecar
DOCLING_SERVICE_URL=http://localhost:8100

# ML Zone Detection — pdfxt cloud service
PDFXT_SERVICE_URL=https://app.pdfxt.com
PDFXT_API_KEY=your_pdfxt_api_key_here

# OnlyOffice Document Server Configuration
# See docker/onlyoffice/README.md for setup instructions
ONLYOFFICE_URL=http://localhost:8080
ONLYOFFICE_JWT_SECRET=your-onlyoffice-jwt-secret-change-in-production
# ONLYOFFICE_CALLBACK_URL=http://localhost:3001/api/v1/editor/callback
# ONLYOFFICE_DOCUMENT_URL=http://localhost:3001/api/v1/editor/document
